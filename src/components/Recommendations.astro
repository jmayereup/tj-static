---
import WorksheetCard from './WorksheetCard.astro';

interface Props {
  posts: any[];
  lang: string;
}

const { posts, lang } = Astro.props;

if (!posts || posts.length === 0) return null;
---

<section class="recommendations mt-16 pt-8 border-t border-slate-100">
  <h2 class="text-2xl font-black text-slate-800 mb-8 flex items-center gap-3">
    <span class="w-8 h-8 rounded-lg bg-blue-600 flex items-center justify-center text-white">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M7 15l5 5 5-5"/><path d="M12 9v11"/><path d="M17 5H7a2 2 0 0 0-2 2v2a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2z"/>
      </svg>
    </span>
    Recommended for You
  </h2>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
    {posts.map((post) => (
      <WorksheetCard post={post} lang={lang} />
    ))}
  </div>
</section>
