---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Contact - Teacher Jake" 
  currentLang="english" 
  currentTag="all"
  description="Get in touch with Teacher Jake for errors, copyright concerns, or material requests."
>
  <div class="max-w-3xl mx-auto bg-white p-8 md:p-12 rounded-2xl shadow-sm border border-slate-100 mt-8 mb-12 px-4 sm:px-8 md:px-12 text-center">
    <h1 class="text-3xl md:text-4xl font-extrabold text-[#06422f] mb-8 tracking-tight">Contact Me</h1>
    
    <div class="prose prose-emerald max-w-none text-slate-600 leading-relaxed font-serif">
      <p class="text-lg mb-8 text-center mx-auto max-w-xl text-slate-600">
        If you spot errors, have copyright concerns, or if you just want to see more of a certain type of material, please reach out!
      </p>

      <div class="bg-emerald-50 p-8 rounded-2xl border border-emerald-100 inline-block mb-10">
        <p class="text-xs uppercase tracking-widest text-emerald-800 font-bold mb-3 font-sans opacity-80">Email address</p>
        <a href="mailto:admin@teacherjake.com" class="text-2xl md:text-3xl font-bold text-emerald-700 hover:text-emerald-900 transition-colors break-all">
          admin@teacherjake.com
        </a>
      </div>

      <p class="mt-4 text-slate-500 italic text-sm">
        I value your feedback and strive to make these resources as helpful as possible for the global teaching community.
      </p>
    </div>
  </div>
</Layout>
