---
import ListingPageLayout from "../../../../../../layouts/ListingPageLayout.astro";
import { getAllPosts } from "../../../../../../lib/ghost-utils";
import { LANGUAGES, CATEGORY_FILTERS, WORKSHEET_TOPICS, getLevelFromTags } from "../../../../../../utils/tags";
import { pb } from "../../../../../../lib/pocketbase";
import { mapPbRecord } from "../../../../../../lib/pb-worksheet-mapper";
import TopicFilter from "../../../../../../components/TopicFilter.astro";

export async function getStaticPaths({ paginate }: any) {
  // ... (keeping existing logic)
  const allPaths: any[] = [];
  const levels = ["a1", "a2", "b1", "b2"];

  // Fetch all PocketBase worksheets once and normalize
  let allPbWorksheets: any[] = [];
  try {
    const records = await pb.collection("worksheets").getFullList({ sort: "-created" });
    allPbWorksheets = await Promise.all(records.map(mapPbRecord));
  } catch (e) {
    console.warn("Failed to fetch PocketBase worksheets for tag/level pages", e);
  }

  for (const langObj of LANGUAGES) {
    const lang = langObj.code;
    let ghostPosts: any[] = [];
    try {
      ghostPosts = await getAllPosts({ filter: `tag:${lang}`, include: ["tags"] });
      ghostPosts = ghostPosts.map((post: any) => ({ ...post, source: "ghost" }));
    } catch (e) {
      console.error(`Failed to fetch Ghost posts for ${lang}`, e);
    }

    const filterCategories = CATEGORY_FILTERS.filter((f: any) => f.id !== "all");
    const worksheetTopics = WORKSHEET_TOPICS;

    const allTags = [...filterCategories, ...worksheetTopics];

    for (const category of allTags) {
      let categoryGhost = ghostPosts.filter((post: any) => {
        if (category.id === 'bilingual') {
          return post.tags?.some((t: any) => t.slug === 'lbl-reader' || t.slug === 'blb');
        }
        return post.tags?.some((t: any) => t.slug === category.id);
      });

      // PB: match by lessonType or Tag
      let categoryPb: any[] = [];
      const isLessonType = ["speaking", "worksheet", "book"].includes(category.id);
      
      if (isLessonType) {
        const typeMatch =
          category.id === "speaking" ? "information-gap" :
          category.id === "book" ? "focused-reading" : "worksheet";
        categoryPb = allPbWorksheets.filter(
          (ws) => ws.language === lang && ws.lessonType === typeMatch
        );
      } else {
        // Topic tag
        categoryPb = allPbWorksheets.filter(
          (ws) => ws.language === lang && ws.tags?.some((t: any) => t.name.toLowerCase() === category.id.toLowerCase())
        );
      }

      for (const level of levels) {
        const levelGhost = categoryGhost.filter(
          (post: any) => getLevelFromTags(post.tags) === level
        );
        const levelPb = categoryPb.filter(
          (ws) => (ws.level || "All").toLowerCase() === level
        );
        const combined = [...levelGhost, ...levelPb].sort((a, b) => {
          const da = new Date(a.published_at || a.created_at || 0).getTime();
          const db = new Date(b.published_at || b.created_at || 0).getTime();
          return db - da;
        });

        const paginated = paginate(combined, {
          params: { lang, tag: category.id, level },
          pageSize: 12,
        });

        if (paginated.length === 0) {
          allPaths.push({
            params: { lang, tag: category.id, level, page: undefined },
            props: {
              page: {
                data: [],
                start: 0, end: 0, total: 0, currentPage: 1, lastPage: 1,
                url: { current: `/${lang}/tag/${category.id}/level/${level}` },
              },
            },
          });
        } else {
          allPaths.push(...paginated);
        }
      }
    }
  }

  return allPaths;
}

const { page } = Astro.props as { page: any };
const { lang, tag, level } = Astro.params;

const titleMap: Record<string, string> = {
  french: "French",
  german: "German",
  spanish: "Spanish",
  english: "English",
  thai: "Thai",
};

const displayLang = titleMap[lang as string] || lang;
const filterLabel = CATEGORY_FILTERS.find((f: any) => f.id === tag)?.label || 
                   WORKSHEET_TOPICS.find((f: any) => f.id === tag)?.label || 
                   (tag as string);

const isWorksheetRelated = tag === 'worksheet' || WORKSHEET_TOPICS.some(t => t.id === tag);
---

<ListingPageLayout
  page={page}
  lang={lang as string}
  displayLang={displayLang || ''}
  tag={tag as string}
  level={level as string}
  filterLabel={filterLabel}
>
  <Fragment slot="title">{displayLang + ' ' + filterLabel}</Fragment>
  
  <Fragment slot="description">
    Browse our collection of interactive {displayLang + ' ' + filterLabel.toLowerCase()} and language learning activities.
  </Fragment>

  {isWorksheetRelated && (
    <TopicFilter 
      slot="extra-filters" 
      currentLang={lang as string} 
      currentTopic={tag as string} 
    />
  )}

  <Fragment slot="empty-state">
    <p class="text-lg font-medium">
      No {displayLang} {level?.toString().toUpperCase()} {(filterLabel as string).toLowerCase()} found.
    </p>
    <p class="mt-2 opacity-80">Check back later for more content.</p>
  </Fragment>
</ListingPageLayout>
