---
import ListingPageLayout from "../../../../layouts/ListingPageLayout.astro";
import { LANGUAGES, getLevelFromTags } from "../../../../utils/tags";
import { pb } from "../../../../lib/pocketbase";
import { mapPbRecord } from "../../../../lib/pb-worksheet-mapper";


export async function getStaticPaths({ paginate }: any) {
  // ... (keeping existing logic)
  const allPaths: any[] = [];
  const levels = ["a1", "a2", "b1", "b2"];

  // Fetch all PocketBase worksheets once and normalize
  let allPbWorksheets: any[] = [];
  try {
    const records = await pb.collection("worksheets").getFullList({ sort: "-created" });
    allPbWorksheets = await Promise.all(records.map(mapPbRecord));
  } catch (e) {
    console.warn("Could not fetch PocketBase worksheets for level pages", e);
  }

  for (const langObj of LANGUAGES) {
    const lang = langObj.code;

    const langPb = allPbWorksheets.filter((ws) => ws.language === lang);

    for (const level of levels) {
      const levelPb = langPb.filter(
        (ws) => (ws.level || "All").toLowerCase() === level
      );
      const combined = [...levelPb].sort((a, b) => {
        const da = new Date(a.published_at || a.created_at || 0).getTime();
        const db = new Date(b.published_at || b.created_at || 0).getTime();
        return db - da;
      });

      const paginated = paginate(combined, {
        params: { lang, level },
        pageSize: 12,
      });

      if (paginated.length === 0) {
        allPaths.push({
          params: { lang, level, page: undefined },
          props: {
            page: {
              data: [],
              start: 0, end: 0, total: 0, currentPage: 1, lastPage: 1,
              url: { current: `/${lang}/level/${level}` },
            },
          },
        });
      } else {
        allPaths.push(...paginated);
      }
    }
  }

  return allPaths;
}

const { page } = Astro.props as { page: any };
const { lang, level } = Astro.params;

const titleMap: Record<string, string> = {
  french: "French",
  german: "German",
  spanish: "Spanish",
  english: "English",
  thai: "Thai",
};

const displayLang = titleMap[lang as string] || lang;
---

<ListingPageLayout
  page={page}
  lang={lang as string}
  displayLang={displayLang || ""}
  level={level as string}
/>
