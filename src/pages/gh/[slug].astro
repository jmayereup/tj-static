---
/**
 * gh/[slug].astro — Static redirect page for legacy Ghost URLs.
 *
 * After migration, Ghost posts live at /pb/[id]. This page generates a
 * static HTML redirect for every old /gh/[slug] URL so existing shared
 * links and search engine results still work.
 *
 * Requires: scripts/ghost-slug-to-pb-id.json (generated by migrate-ghost-to-pb.mjs)
 */
import fs from 'node:fs';
import path from 'node:path';

export async function getStaticPaths() {
  // Load the slug → PB ID map generated by the migration script.
  const mapPath = path.join(process.cwd(), 'scripts', 'ghost-slug-to-pb-id.json');

  if (!fs.existsSync(mapPath)) {
    console.warn('[gh/[slug].astro] ghost-slug-to-pb-id.json not found — no Ghost redirect pages will be generated. Run scripts/migrate-ghost-to-pb.mjs first.');
    return [];
  }

  const slugMap: Record<string, string> = JSON.parse(fs.readFileSync(mapPath, 'utf-8'));

  return Object.entries(slugMap).map(([slug, pbId]) => ({
    params: { slug },
    props: { pbId },
  }));
}

const { slug } = Astro.params;
const { pbId } = Astro.props as { pbId: string };

const redirectUrl = `/pb/${pbId}`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Redirecting…</title>
    <meta http-equiv="refresh" content={`0; url=${redirectUrl}`} />
    <link rel="canonical" href={redirectUrl} />
  </head>
  <body>
    <p>
      This page has moved. <a href={redirectUrl}>Click here if you are not redirected automatically.</a>
    </p>
  </body>
</html>
